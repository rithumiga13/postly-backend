meta {
  name: Update Profile
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/api/v1/user/profile
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "Updated Name",
    "bio": "My updated bio",
    "defaultTone": "casual",
    "defaultLanguage": "en"
  }
}
