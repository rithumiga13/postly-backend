meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "test@postly.dev",
    "password": "secret123"
  }
}

script:post-response {
  const data = res.getBody();
  if (data && data.data && data.data.accessToken) {
    bru.setVar("accessToken", data.data.accessToken);
  }
}
