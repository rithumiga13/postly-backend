{
  "name": "postly-backend",
  "version": "0.1.0",
  "description": "Postly social scheduling backend",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postly_test NODE_ENV=test node --experimental-vm-modules node_modules/.bin/jest --forceExit",
    "test:db:setup": "DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postly_test npx prisma migrate deploy",
    "lint": "eslint src --ext .js",
    "postinstall": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "worker": "node src/worker.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@prisma/client": "^5.14.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.7.0",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "grammy": "^1.26.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "openai": "^6.34.0",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.2",
    "prisma": "^5.14.0",
    "supertest": "^7.2.2"
  }
}
